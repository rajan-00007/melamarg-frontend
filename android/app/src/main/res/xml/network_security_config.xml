<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic for all domains (dev builds) -->
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="true">
        <!-- USB tethering: the PC's IP as seen from the Android phone -->
        <domain includeSubdomains="true">192.168.42.129</domain>
        <!-- USB tethering full subnet -->
        <domain includeSubdomains="true">192.168.42.1</domain>
        <!-- Android emulator alias for host localhost -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Common LAN subnets -->
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>
        <!-- Linux USB tethering subnet -->
        <domain includeSubdomains="true">10.42.0.1</domain>
        <!-- Localhost -->
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
